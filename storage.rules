rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /works/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /editor-images/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
